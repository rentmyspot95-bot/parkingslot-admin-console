# Base URL for the admin API. In dev, leave as the relative prefix so Vite's
# proxy (vite.config.ts) forwards to VITE_API_PROXY_TARGET and avoids CORS.
# In prod, set to the absolute admin API origin.
VITE_API_BASE_URL=/api/v1/admin

# Dev-only: where the Vite proxy forwards /api requests.
VITE_API_PROXY_TARGET=https://api.parkingslot.com

# Environment badge shown in the top bar: production | staging | development
VITE_ENV_NAME=development

# Optional Sentry DSN for front-end error reporting.
VITE_SENTRY_DSN=

# Dev-only: when 'true', serve the admin API from in-memory fixtures so the app
# runs with no backend (login: admin@parkingslot.com / admin). Off in production.
VITE_USE_MOCK=false
